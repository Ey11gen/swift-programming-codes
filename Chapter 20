import SwiftUI
import Observation

@Observable @MainActor
class SearchViewModel {
    var query:        String = ""
    var results:      [Book] = []
    var isSearching:  Bool = false
    var errorMessage: String? = nil
    private var searchTask: Task<Void, Never>?

    func search() {
        searchTask?.cancel()
        let q = query
        guard !q.trimmingCharacters(in: .whitespaces).isEmpty else { results = []; return }
        searchTask = Task {
            isSearching = true; errorMessage = nil
            do {
                try await Task.sleep(nanoseconds: 400_000_000)
                guard !Task.isCancelled else { isSearching = false; return }
                results     = try await BookSearchService.shared.search(query: q)
                isSearching = false
            } catch is CancellationError { isSearching = false }
            catch { errorMessage = error.localizedDescription; isSearching = false }
        }
    }
}

@Observable @MainActor
class ReadingListViewModel {
    var selectedFilter: ReadingStatus? = nil
    var sortByTitle:    Bool = false

    func filtered(_ records: [ReadingRecord]) -> [ReadingRecord] {
        var list = records
        if let filter = selectedFilter { list = list.filter { $0.status == filter } }
        return sortByTitle ? list.sorted { $0.title < $1.title } : list.sorted { $0.addedDate > $1.addedDate }
    }
}
