import Foundation

actor BookSearchService {
    static let shared = BookSearchService()
    private let baseURL = "https://www.googleapis.com/books/v1/volumes"

    func search(query: String, maxResults: Int = 20) async throws -> [Book] {
        guard !query.trimmingCharacters(in: .whitespaces).isEmpty else { return [] }
        var components = URLComponents(string: baseURL)!
        components.queryItems = [
            URLQueryItem(name: "q",           value: query),
            URLQueryItem(name: "maxResults",   value: String(maxResults)),
            URLQueryItem(name: "printType",    value: "books"),
            URLQueryItem(name: "langRestrict", value: "en"),
        ]
        guard let url = components.url else { throw URLError(.badURL) }
        let (data, response) = try await URLSession.shared.data(from: url)
        guard let http = response as? HTTPURLResponse, (200...299).contains(http.statusCode) else {
            throw URLError(.badServerResponse)
        }
        return (try JSONDecoder().decode(BookSearchResponse.self, from: data)).items?.map { $0.toBook() } ?? []
    }
}

