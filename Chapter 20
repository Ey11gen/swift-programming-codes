            }
            .buttonStyle(.plain)
        }
        .padding(.vertical, 4)
    }
}

// MARK: - Library

struct LibraryView: View {
    @Query(sort: \ReadingRecord.addedDate, order: .reverse) private var records: [ReadingRecord]
    @State private var viewModel = ReadingListViewModel()
    @State private var selectedRecord: ReadingRecord? = nil
    @Environment(\.modelContext) private var context

    var body: some View {
        NavigationStack {
            VStack(spacing: 0) {
                filterBar; Divider()
                let displayed = viewModel.filtered(records)
                if displayed.isEmpty {
                    Text(records.isEmpty ? "Add books from Search." : "No books match this filter.")
                        .foregroundStyle(.secondary).padding()
                } else {
                    List {
                        ForEach(displayed) { record in
                            Button { selectedRecord = record } label: { LibraryRowView(record: record) }
                                .buttonStyle(.plain)
                        }
                        .onDelete { offsets in offsets.forEach { context.delete(displayed[$0]) } }
                    }
                    .listStyle(.plain)
                }
            }
            .navigationTitle("My Library")
            .sheet(item: $selectedRecord) { record in RecordDetailView(record: record) }
        }
    }

    private var filterBar: some View {
        ScrollView(.horizontal, showsIndicators: false) {
            HStack(spacing: 8) {
                FilterChip(label: "All", isSelected: viewModel.selectedFilter == nil) { viewModel.selectedFilter = nil }
                ForEach(ReadingStatus.allCases, id: \.self) { s in
                    FilterChip(label: s.rawValue, isSelected: viewModel.selectedFilter == s) { viewModel.selectedFilter = s }
                }
            }
            .padding(.horizontal)
        }
        .padding(.vertical, 8)
    }
}

struct FilterChip: View {
