// MARK: - Counter with @State

struct CounterView: View {
    @State private var count: Int = 0
    @State private var step: Int  = 1

    var body: some View {
        VStack(spacing: 20) {
            Text("Count: \(count)").font(.largeTitle).fontWeight(.bold)
            HStack(spacing: 20) {
                Button("Decrease") { count -= step }.buttonStyle(.bordered)
                Button("Increase") { count += step }.buttonStyle(.borderedProminent)
            }
            HStack {
                Text("Step: \(step)")
                Stepper("", value: $step, in: 1...10)
            }
            Button("Reset") { count = 0; step = 1 }.foregroundStyle(.red)
        }
        .padding()
    }
}

// MARK: - Login Form

struct LoginFormView: View {
    @State private var username: String = ""
    @State private var password: String = ""
    @State private var statusMessage: String = ""

    var body: some View {
        VStack(spacing: 16) {
            Text("Sign In").font(.title).bold()
            TextField("Username", text: $username)
                .textFieldStyle(.roundedBorder)
                .autocapitalization(.none)
            SecureField("Password", text: $password)
                .textFieldStyle(.roundedBorder)
            Button("Sign In") {
                if username.isEmpty || password.isEmpty {
                    statusMessage = "Please fill in all fields."
                } else {
                    statusMessage = "Welcome, \(username)!"
                }
            }
            .buttonStyle(.borderedProminent)
            Text(statusMessage).foregroundStyle(.secondary).font(.callout)
        }
        .padding(24)
    }
}

// MARK: - Task Manager (Complete App)

struct TodoTask: Identifiable {
    let id: UUID = UUID()
    var title: String
    var isCompleted: Bool = false
}

struct TaskRowView: View {
    let task: TodoTask
    let onToggle: () -> Void
    var body: some View {
        HStack(spacing: 12) {
            Button(action: onToggle) {
                Image(systemName: task.isCompleted ? "checkmark.circle.fill" : "circle")
                    .font(.title2)
                    .foregroundStyle(task.isCompleted ? .green : .secondary)
            }
            .buttonStyle(.plain)
            Text(task.title)
                .strikethrough(task.isCompleted)
                .foregroundStyle(task.isCompleted ? .secondary : .primary)
            Spacer()
        }
        .padding(.vertical, 4)
    }
}

struct ContentView: View {
    @State private var tasks: [TodoTask] = [
        TodoTask(title: "Learn SwiftUI basics"),
        TodoTask(title: "Build a simple app"),
        TodoTask(title: "Read Chapter 14")
    ]
    @State private var newTaskTitle: String = ""
    @State private var showingCompletedOnly: Bool = false

    var displayedTasks: [TodoTask] {
        showingCompletedOnly ? tasks.filter { $0.isCompleted } : tasks
    }
    var completedCount: Int { tasks.filter { $0.isCompleted }.count }

    var body: some View {
        NavigationStack {
            VStack(spacing: 0) {
                HStack {
                    Text("\(completedCount) of \(tasks.count) completed")
                        .font(.subheadline).foregroundStyle(.secondary)
                    Spacer()
                    Toggle("Show completed", isOn: $showingCompletedOnly).labelsHidden()
                }
                .padding(.horizontal).padding(.vertical, 8)
                Divider()
                List {
                    ForEach(displayedTasks) { task in
                        TaskRowView(task: task) { toggleTask(id: task.id) }
                    }
                    .onDelete(perform: deleteTasks)
                }
                .listStyle(.plain)
                Divider()
                HStack {
                    TextField("New task...", text: $newTaskTitle).textFieldStyle(.roundedBorder)
                    Button("Add") { addTask() }
                        .buttonStyle(.borderedProminent)
                        .disabled(newTaskTitle.trimmingCharacters(in: .whitespaces).isEmpty)
                }
                .padding()
            }
            .navigationTitle("My Tasks")
        }
    }

    func addTask() {
        let title = newTaskTitle.trimmingCharacters(in: .whitespaces)
        guard !title.isEmpty else { return }
        tasks.append(TodoTask(title: title))
        newTaskTitle = ""
    }
    func toggleTask(id: UUID) {
        if let i = tasks.firstIndex(where: { $0.id == id }) { tasks[i].isCompleted.toggle() }
    }
    func deleteTasks(at offsets: IndexSet) {
        let ids = offsets.map { displayedTasks[$0].id }
        tasks.removeAll { ids.contains($0.id) }
    }
}

