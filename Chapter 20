import SwiftData
import Foundation

enum ReadingStatus: String, Codable, CaseIterable {
    case wantToRead       = "Want to Read"
    case currentlyReading = "Reading"
    case finished         = "Finished"
}

@Model
class ReadingRecord {
    var bookID: String; var title: String; var authors: String
    var thumbnail: String?; var pageCount: Int; var pagesRead: Int
    var statusRaw: String; var personalNote: String
    var startDate: Date?; var finishDate: Date?; var addedDate: Date; var rating: Int

    var status: ReadingStatus {
        get { ReadingStatus(rawValue: statusRaw) ?? .wantToRead }
        set { statusRaw = newValue.rawValue }
    }
    var progressPercent: Double {
        guard pageCount > 0 else { return 0 }
        return min(Double(pagesRead) / Double(pageCount), 1.0)
    }
    var progressDisplay: String { "\(pagesRead) / \(pageCount) pages" }

    init(from book: Book) {
        self.bookID = book.id; self.title = book.title; self.authors = book.authorDisplay
        self.thumbnail = book.thumbnail; self.pageCount = book.pageCount ?? 0
        self.pagesRead = 0; self.statusRaw = ReadingStatus.wantToRead.rawValue
        self.personalNote = ""; self.addedDate = Date(); self.rating = 0
    }
}

