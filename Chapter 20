}

struct LibraryRowView: View {
    let record: ReadingRecord
    var body: some View {
        HStack(spacing: 12) {
            AsyncImage(url: record.thumbnail.flatMap(URL.init)) { img in img.resizable().scaledToFill() }
                placeholder: { Rectangle().fill(.secondary.opacity(0.2)) }
                .frame(width: 44, height: 62).cornerRadius(4)
            VStack(alignment: .leading, spacing: 4) {
                Text(record.title).font(.headline).lineLimit(1)
                Text(record.authors).font(.subheadline).foregroundStyle(.secondary)
                if record.status == .currentlyReading {
                    ProgressView(value: record.progressPercent).tint(.blue)
                    Text(record.progressDisplay).font(.caption).foregroundStyle(.secondary)
                } else {
                    Text(record.status.rawValue).font(.caption)
                        .foregroundStyle(record.status == .finished ? .green : .secondary)
                }
            }
            Spacer()
            if record.rating > 0 {
                HStack(spacing: 1) {
                    ForEach(1...record.rating, id: \.self) { _ in
                        Image(systemName: "star.fill").font(.caption2).foregroundStyle(.yellow)
                    }
                }
            }
        }
        .padding(.vertical, 4)
    }
}

// MARK: - Record Detail

struct RecordDetailView: View {
    @Bindable var record: ReadingRecord
    @Environment(\.dismiss) private var dismiss
    var body: some View {
        NavigationStack {
            Form {
                Section("Status") {
                    Picker("Status", selection: $record.status) {
                        ForEach(ReadingStatus.allCases, id: \.self) { Text($0.rawValue).tag($0) }
                    }
                    .pickerStyle(.segmented)
                }
                if record.status == .currentlyReading {
                    Section("Progress") {
                        Stepper("Pages read: \(record.pagesRead)", value: $record.pagesRead, in: 0...max(record.pageCount,1), step: 10)
                        ProgressView(value: record.progressPercent).tint(.blue)
                        Text(record.progressDisplay).font(.caption).foregroundStyle(.secondary)
                    }
                }
                if record.status == .finished {
                    Section("Rating") {
                        HStack {
                            ForEach(1...5, id: \.self) { star in
                                Image(systemName: star <= record.rating ? "star.fill" : "star")
                                    .foregroundStyle(.yellow).font(.title2)
                                    .onTapGesture { record.rating = star }
                            }
                        }
                    }
                }
                Section("Personal Notes") {
                    TextEditor(text: $record.personalNote).frame(minHeight: 100)
                }
                Section("Book Details") {
                    LabeledContent("Title",  value: record.title)
                    LabeledContent("Author", value: record.authors)
                    if record.pageCount > 0 { LabeledContent("Pages", value: "\(record.pageCount)") }
                    LabeledContent("Added",  value: record.addedDate.formatted(date: .abbreviated, time: .omitted))
                }
            }
            .navigationTitle(record.title).navigationBarTitleDisplayMode(.inline)
            .toolbar { ToolbarItem(placement: .confirmationAction) { Button("Done") { dismiss() } } }
        }
    }
}

// MARK: - Statistics

struct StatisticsView: View {
    @Query private var allRecords: [ReadingRecord]
    var finished:       [ReadingRecord] { allRecords.filter { $0.status == .finished } }
    var currentlyRead:  [ReadingRecord] { allRecords.filter { $0.status == .currentlyReading } }
    var totalPagesRead: Int             { allRecords.reduce(0) { $0 + $1.pagesRead } }
    var averageRating:  Double {
        let rated = finished.filter { $0.rating > 0 }
        guard !rated.isEmpty else { return 0 }
        return Double(rated.reduce(0) { $0 + $1.rating }) / Double(rated.count)
    }
    var body: some View {
        NavigationStack {
            List {
                Section("Overview") {
                    StatRow(label: "Total books",       value: "\(allRecords.count)")
                    StatRow(label: "Finished",          value: "\(finished.count)")
                    StatRow(label: "Currently reading", value: "\(currentlyRead.count)")
                    StatRow(label: "Total pages read",  value: totalPagesRead.formatted())
                    if averageRating > 0 {
                        StatRow(label: "Average rating", value: String(format: "%.1f / 5.0", averageRating))
                    }
                }
            }
            .navigationTitle("Statistics")
        }
    }
}

struct StatRow: View {
    let label: String; let value: String
    var body: some View {
        HStack { Text(label); Spacer(); Text(value).foregroundStyle(.secondary).font(.subheadline) }
    }
}

